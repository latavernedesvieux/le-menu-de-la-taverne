<style>
  :root{
    --bg:#0f1115;
    --card:#181b22;
    --card-hover:#1e222b;
    --line:#262b36;
    --text:#e9ecf1;
    --muted:#8b93a2;
    --gold:#e0a95c;
    --cyan:#5fc9c9;
    --green:#6fc98f;
    --blue:#7ba7e0;
    --red:#e07b7b;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{
    font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
    background:var(--bg);
    color:var(--text);
    line-height:1.4;
    padding:32px 16px 80px;
    -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:820px;margin:0 auto;}

  header{margin-bottom:24px;}
  h1{font-size:26px;font-weight:800;letter-spacing:-0.5px;}
  h1 .accent{color:var(--gold);}
  .sub{color:var(--muted);font-size:13px;margin-top:4px;}

  /* Stat counters */
  .stats{
    display:flex;
    gap:10px;
    margin:20px 0 24px;
    flex-wrap:wrap;
  }
  .stat{
    flex:1;
    min-width:90px;
    background:var(--card);
    border:1px solid var(--line);
    border-radius:12px;
    padding:12px 14px;
  }
  .stat .num{font-size:22px;font-weight:800;line-height:1;}
  .stat .lbl{font-size:11px;color:var(--muted);margin-top:4px;text-transform:uppercase;letter-spacing:.5px;}
  .stat.w .num{color:var(--gold);}
  .stat.u .num{color:var(--cyan);}
  .stat.c .num{color:var(--green);}
  .stat.t .num{color:var(--blue);}

  /* Filters */
  .filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:22px;}
  .chip{
    background:var(--card);
    border:1px solid var(--line);
    color:var(--muted);
    font-size:12px;
    font-weight:600;
    padding:7px 14px;
    border-radius:20px;
    cursor:pointer;
    transition:all .15s ease;
    font-family:inherit;
  }
  .chip:hover{border-color:var(--gold);color:var(--text);}
  .chip.active{background:var(--gold);color:#1a1305;border-color:var(--gold);}

  /* Section groups */
  .group-title{
    font-size:12px;
    font-weight:700;
    text-transform:uppercase;
    letter-spacing:1px;
    color:var(--muted);
    margin:26px 0 12px;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .group-title::after{content:"";flex:1;height:1px;background:var(--line);}
  .group-title .dot{width:8px;height:8px;border-radius:50%;}
  .dot-watching{background:var(--gold);}
  .dot-uptodate{background:var(--cyan);}
  .dot-onhold{background:var(--red);}
  .dot-towatch{background:var(--blue);}
  .dot-completed{background:var(--green);}

  /* Cards */
  .card{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:12px;
    padding:14px 16px;
    margin-bottom:10px;
    display:flex;
    align-items:center;
    gap:14px;
    transition:background .15s ease;
  }
  .card:hover{background:var(--card-hover);}
  .card-main{flex:1;min-width:0;}
  .card-title{font-weight:600;font-size:15px;}
  .card-notes{color:var(--muted);font-size:12px;margin-top:3px;}
  .card-right{
    display:flex;
    align-items:center;
    gap:16px;
    flex-shrink:0;
  }
  .prog{text-align:right;}
  .prog .lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}
  .prog .val{font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:600;color:var(--gold);margin-top:1px;}
  .prog .val.dim{color:var(--muted);}
  .retard{
    font-size:11px;
    font-weight:600;
    padding:3px 8px;
    border-radius:10px;
    white-space:nowrap;
    min-width:70px;
    text-align:center;
  }
  .retard.ok{background:rgba(111,201,143,.12);color:var(--green);}
  .retard.late{background:rgba(224,169,92,.12);color:var(--gold);}
  .retard.none{color:var(--muted);}

  @media(max-width:560px){
    .card{flex-wrap:wrap;gap:10px;}
    .card-right{width:100%;justify-content:space-between;}
    .prog{text-align:left;}
  }

  .footer-note{
    color:var(--muted);
    font-size:11px;
    margin-top:32px;
    padding-top:16px;
    border-top:1px solid var(--line);
    line-height:1.6;
  }
  .footer-note code{background:var(--card);padding:1px 5px;border-radius:4px;color:var(--gold);font-size:11px;}
</style>
</head>
