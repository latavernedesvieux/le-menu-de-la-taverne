const statusLabels = { watching:"En cours", uptodate:"À jour", onhold:"En pause", towatch:"À voir", completed:"Terminée" };
const statusOrder  = { watching:0, uptodate:1, onhold:2, towatch:3, completed:4 };
const groupList = [
  { key:"watching",  label:"En cours de visionnage" },
  { key:"uptodate",  label:"À jour (pas encore terminées)" },
  { key:"onhold",    label:"En pause" },
  { key:"towatch",   label:"À voir" },
  { key:"completed", label:"Terminées" },
];

let currentFilter = 'all';
function pad(n){ return String(n).padStart(2,'0'); }

function renderStats(){
  const count = k => shows.filter(s=>s.status===k).length;
  document.getElementById('stats').innerHTML = `
    <div class="stat w"><div class="num">${count('watching')}</div><div class="lbl">En cours</div></div>
    <div class="stat u"><div class="num">${count('uptodate')}</div><div class="lbl">À jour</div></div>
    <div class="stat t"><div class="num">${count('towatch')+count('onhold')}</div><div class="lbl">À voir / pause</div></div>
    <div class="stat c"><div class="num">${count('completed')}</div><div class="lbl">Terminées</div></div>
  `;
}

function renderFilters(){
  const filters = [{key:'all',label:'Toutes'}, ...groupList.map(g=>({key:g.key,label:statusLabels[g.key]}))];
  document.getElementById('filters').innerHTML = filters.map(f=>
    `<button class="chip ${currentFilter===f.key?'active':''}" onclick="setFilter('${f.key}')">${f.label}</button>`
  ).join('');
}

function setFilter(f){ currentFilter=f; renderFilters(); renderList(); }

function cardHTML(s){
  const hasAvail = s.availableSeason!=null;
  const availText = hasAvail ? `S${pad(s.availableSeason)}` : '—';
  let retard='—', cls='none';
  if(hasAvail){
    if(s.availableSeason > s.season){
      const sb = s.availableSeason - s.season;
      retard = `${sb} saison${sb>1?'s':''} de retard`;
      cls='late';
    } else if(s.availableSeason === s.season){ retard='à jour'; cls='ok'; }
  }
  return `
    <div class="card">
      <div class="card-main">
        <div class="card-title">${s.title}</div>
        ${s.notes ? `<div class="card-notes">${s.notes}</div>` : ''}
      </div>
      <div class="card-right">
        <div class="prog"><div class="lbl">Ma saison</div><div class="val">S${pad(s.season)}</div></div>
        <div class="prog"><div class="lbl">Sortie</div><div class="val dim">${availText}</div></div>
        <div class="retard ${cls}">${retard}</div>
      </div>
    </div>`;
}

function renderList(){
  const container = document.getElementById('list');
  const groups = currentFilter==='all' ? groupList : groupList.filter(g=>g.key===currentFilter);
  let html='';
  let total=0;
  groups.forEach(g=>{
    const items = shows.filter(s=>s.status===g.key).sort((a,b)=>a.title.localeCompare(b.title));
    if(items.length===0) return;
    total+=items.length;
    html += `<div class="group-title"><span class="dot dot-${g.key}"></span>${g.label} · ${items.length}</div>`;
    html += items.map(cardHTML).join('');
  });
  container.innerHTML = total ? html : `<div style="color:#666;text-align:center;padding:40px;">Rien ici.</div>`;
}

renderStats();
renderFilters();
renderList();
